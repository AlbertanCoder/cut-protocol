# Dependencies
**/node_modules

# Build output
**/dist
release/
backend/prisma/dev.db.template

# Env / secrets
**/.env
**/.env.local

# Local databases + phase backups
backend/prisma/dev.db
backend/prisma/dev.db-journal
backend/prisma/dev.db.backup-*
*.db
*.db-journal
# Snapshot copies taken during agent/QC runs carry the same personal health
# data as dev.db but don't end in .db, so the rules above miss them. The repo
# is PUBLIC — an `add -A` on one of these publishes a real person's records.
backend/prisma/dev.db.snapshot-*
*.db.snapshot-*

# Git bundles used to shuttle work between machines/sessions. They contain
# full history and are regenerable; never commit one into the history it holds.
*.bundle

# Audit/fix run artifacts (regenerate with scripts/auditFoodData.mjs)
backend/reports/

# Logs
*.log
npm-debug.log*

# OS junk
.DS_Store
Thumbs.db

# Editor folders
.vscode/*
!.vscode/extensions.json
.idea/

# Internal dev docs — local-only (contain personal/health data).
# CLAUDE.md itself is now tracked: rewritten in Phase 0 with generic rules only.
CLAUDE_RECOMP_ARCHIVE.md
AUDIT.md
PABLO_REVIEW.md
roadmap/09-ux-onboarding.md
HANDOFF.md

# Design-inspiration library — local-only. Scraped third-party imagery
# (Dribbble shots, vendor marketing mockups); must never ship in the
# public repo. Browse locally via docs/design/inspiration/contact-sheet.html
docs/design/inspiration/

# QC gauntlet raw per-run stream (regenerable; report + failures are committed)
docs/qc/mc-results.jsonl
backend/.env.qc
