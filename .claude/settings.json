      "Bash(git push)",
      "Bash(git push origin:*)",
      "Bash(git branch:*)",
      "Bash(git tag:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git pull:*)",
      "Bash(git stash:*)",
      "PowerShell(npm:*)",
      "PowerShell(npx:*)",
      "PowerShell(node:*)",
      "PowerShell(git status:*)",
      "PowerShell(git diff:*)",
      "PowerShell(git log:*)",
      "PowerShell(git add:*)",
      "PowerShell(git commit:*)",
      "PowerShell(git push)",
      "PowerShell(git push origin:*)",
      "PowerShell(git branch:*)",
      "PowerShell(git tag:*)",
      "PowerShell(git checkout:*)"
