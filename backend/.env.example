# Copy this file to .env and fill in real values. .env is gitignored and
# should never be committed.

# SQLite for local dev. Prisma supports Postgres/MySQL/SQL Server/MongoDB
# connection strings too — see https://pris.ly/d/connection-strings
DATABASE_URL="file:./dev.db"

PORT=3001

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# USDA FoodData Central API key (free): https://fdc.nal.usda.gov/api-key-signup
USDA_API_KEY=

# Anthropic API key, used for AI recipe generation: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Used once by `npm run seed` to create your login. Set these to your own
# values, then you can blank SEED_PASSWORD back out after seeding if you want.
SEED_EMAIL=you@example.com
SEED_PASSWORD=change-me
