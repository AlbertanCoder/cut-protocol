// Schema intentionally avoids Postgres-only features (native enums, arrays)
// so it's a one-line provider swap ("sqlite" -> "postgresql") at deploy time.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  // "user" | "admin". Added for the recipe-ownership fix (roadmap/05-data-isolation-audit.md,
  // roadmap/04-multi-tenancy-auth.md - both independently found the same gap):
  // Recipe is a shared library with no owner column, and PUT/DELETE
  // /api/recipes/:id had zero ownership check - harmless while there's one
  // seeded account, armed the moment self-registration ships (any user could
  // edit/delete any other user's or the curated library's recipes, cascading
  // to silently wipe other users' carts/plan slots per the schema's own
  // onDelete rules below). "admin" can mutate any recipe (the existing
  // curated/AI-generated library, which predates per-user ownership and has
  // no createdByUserId); a plain "user" can only mutate recipes they created.
  role         String    @default("user")
  createdAt    DateTime  @default(now())
  profile      Profile?
  weighins     Weighin[]
  plans        Plan[]
  cartItems    CartItem[]
  recipes      Recipe[]
  trainingPlan TrainingPlan?
  mealLogs     MealLog[]
  llmUsage     LlmUsage[]
  brainPreference BrainPreference?
}

// All physical quantities stored in SI (kg, cm) regardless of the user's
// display unit preference — conversion happens at the UI boundary only.
model Profile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  sex             String // "M" | "F"
  age             Int
  heightCm        Float
  bodyFatPct      Float // 0 = unknown (Katch-McArdle/Cunningham auto-hide)
  // E2 (v2): how bodyFatPct was set. "visual-estimate" (silhouette bucket) |
  // "measured" (DEXA/calipers/scale) | null (unset). Additive, nullable — a pure
  // ADD COLUMN, no table rebuild. bodyFatPct stays 0 = unknown (engine dual-
  // accepts 0 or null), so no existing touchpoint changes.
  bodyFatSource   String?
  // Phase 3 activity model: occupation picked from activityData.js's table
  // (many real occupations -> multiplier), with an optional manual override.
  occupationKey    String  @default("desk-office")
  activityOverride Float? // manual job-multiplier override; null = use occupation
  sessionsPerWeek Int
  trainingStyle     String @default("mixed") // "weights" | "cardio" | "mixed" | "sport"
  minutesPerSession Int    @default(45)
  startWeightKg   Float
  goalWeightKg    Float
  startDate       String // ISO date (yyyy-mm-dd)
  unitPref        String   @default("imperial") // "imperial" | "metric"
  // Phase 3 prescription model: targetKcal is DERIVED (TDEE - rate*500,
  // clamped to the floor) and re-materialized server-side whenever profile
  // or weight changes — never set directly by the client anymore.
  rateLbPerWeek    Float   @default(1.0) // 0.25|0.5|0.75|1.0|1.25|1.5|2.0
  rateAcknowledged Boolean @default(false) // explicit "I understand" for unsafe rates
  floorKcal        Int? // optional user-stricter floor; effective floor = max(sex floor, this)
  // JSON string array of BMR formula keys the user excluded from the average
  // (same no-@default Json convention as excludedFoods below).
  excludedFormulas Json
  targetKcal      Int
  mealsPerDay     Int      @default(3)
  snacksPerDay    Int      @default(1)
  // JSON string array, not a native list — this schema deliberately avoids
  // Postgres-only array types (see file header), and SQLite has no list type
  // for Prisma to fall back to. No @default() here on purpose — matches
  // every other Json field in this schema (Recipe.steps, PlanSlot.ingredients,
  // GroceryList.items), none of which have one either. @default("[]") was
  // tried and found broken: Prisma/SQLite generated `DEFAULT []` (unquoted,
  // invalid JSON) in the migration SQL, silently corrupting existing rows
  // with an empty string instead of "[]" — application code (profile.js's
  // defaultProfile()) always supplies this explicitly on create instead.
  excludedFoods   Json // e.g. ["shellfish","gluten"]
  dietaryStyle    String? // e.g. "omnivore" | "pescatarian" | "vegetarian" | "vegan" | "keto" | "paleo" — null = no restriction
  // AI recipe-generation preferences (recipeGeneration.js's
  // generateAndSaveSlotRecipe()). Json array, no @default() - same reason as
  // excludedFoods above (Prisma/SQLite generated broken unquoted JSON for
  // @default("[]") once already; app code (defaultProfile()) supplies it).
  cuisinePreferences Json // e.g. ["mexican","thai","mediterranean"]
  mealPreferencesNote String? // freeform, e.g. "high protein, minimal dairy, I have an air fryer"
  // Brain v3 Stage G — SOFT meal-planning preferences (null = no constraint).
  // Read by the brain's compileConstraints() as relaxable soft limits; they can
  // never override a HARD constraint (diet/allergy exclusions, energy, protein
  // floor). Additive + nullable: existing rows and the deterministic solver are
  // unaffected, and with the brain OFF nothing reads them.
  maxPrepMin      Int? // max acceptable recipe prep time in minutes
  budgetTier      String? // "cheap" | "moderate" | "premium"
  allowBatch      Boolean? // allow batch-cooking repeats past the variety cap
  maxComplexity   Int? // recipe complexity ceiling (1 = simplest)
  // Adaptive-TDEE opt-out. Default ON because the estimator beats the static
  // formula on measured error (155 vs 359 kcal median at 28 days), but every
  // automatic adjustment must be reversible per the constitution, and "turn it
  // off entirely" is the strongest form of that. Read by adaptiveTarget
  // .adaptiveEnabled(); `false` means off. An install-wide ADAPTIVE_TDEE=off env
  // switch already exists — this makes it per-account and visible in the UI.
  adaptiveTdee    Boolean  @default(true)
  // Protein-priority (recomposition) solving. Default OFF: it changes what the
  // solver optimises, so it is opt-in rather than something that silently
  // reweights plans. Was localStorage-only, which meant the choice did not
  // survive a reinstall or a second device.
  proteinPriorityMode Boolean @default(false)
  updatedAt       DateTime @updatedAt
}

model Weighin {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      String // ISO date (yyyy-mm-dd)
  weightKg  Float
  // Optional per-weigh-in body fat %, so lean mass can become a MEASURED trend
  // instead of an estimate projected from one current reading. The recomp mode
  // charts lean mass, and two people losing identical scale weight can have
  // opposite outcomes — that distinction is the whole point of the product, so
  // it should be able to rest on real data when the user has it. Null is the
  // normal case and stays honestly absent; the chart falls back to the bounded
  // estimate and says so.
  bodyFatPct Float?
  createdAt DateTime @default(now())

  @@unique([userId, date])
}

// Foods/recipes are a shared library, not per-user — this is a single-user
// app for now, and a shared curated library is the simpler model regardless.
// Bulk-import scale change: `name` was @unique when this table held ~864 curated
// rows. A USDA FoodData Central import (Foundation + SR Legacy + FNDDS) collides on
// that constraint immediately — FDC ships duplicate descriptions across its datasets,
// and Open Food Facts branded rows collide harder still. Uniqueness therefore moves
// off the display name and onto the two real external identifiers. Nullable @unique
// permits many NULLs under SQLite, so hand-entered foods are unaffected.
model Food {
  id       String   @id @default(cuid())
  name     String
  category String // "protein" | "carb" | "veg" | "fat" | "dairy" | "other"
  // @unique — THE structural fix for the provenance corruption. One FDC record's
  // macros were copied onto six different curry/tahini/garlic pastes (fdcId 170160,
  // "Nuts, almond paste"); the final count was 472 of 738 id-claiming rows wrong,
  // touching 874 of 889 recipes. With this constraint that class of bug is
  // UNREPRESENTABLE: one FDC id can only ever belong to one row, so a fuzzy matcher
  // cannot spread one record across many foods no matter how confident it is.
  //
  // Deferred at first because 140 duplicate groups made it un-appliable. Cleared in
  // three passes: the provenance repair (472 rows verified/rematched/downgraded),
  // then scripts/mergeSynonymFoods.mjs (22 genuine synonym pairs merged with 93
  // ingredient references re-pointed), then one documented mislabel — the row named
  // "Rye" carried FDC "Bread, rye" macros and was downgraded off the verified tier
  // rather than merged, because merging would have hidden a wrong number behind a
  // trusted label. SQLite exempts NULLs, so hand-entered foods are unaffected.
  // See docs/audit/food-provenance-integrity.md.
  fdcId    Int?     @unique // USDA FoodData Central id — null for hand-entered items
  upc      String?  @unique // barcode / GTIN for Open Food Facts lookups — null for unbranded
  brand    String? // branded-food manufacturer; null for generic/whole foods
  // per 100g
  kcal     Float
  protein  Float
  fat      Float
  carb     Float
  fiber    Float    @default(0)
  // Provenance tier — never silently mixed, always visibly distinct in the UI.
  // "usda-verified" (FDC Foundation/SR Legacy/FNDDS, Atwater-validated)
  // "label"         (manufacturer-declared panel)
  // "community"     (Open Food Facts — crowd-sourced, lower trust, tagged as such)
  // "ai-estimated"  (model-derived, always carries "verify me")
  // "manual" | "manual-placeholder" (hand-entered, pre-import legacy rows)
  source   String   @default("manual")
  // Fiber-adjusted-Atwater validator verdict recorded at import time:
  // "pass" | "warn:<reason>" | "exception:<documented-reason>". Null = not yet run
  // (all pre-import rows). Surfaced by the startup [data-audit] report.
  dataQuality String?
  // Micronutrients per 100g as { nutrientKey: amount } in the canonical units
  // declared by the nutrient registry (see backend/src/lib/nutrients.js). Stored as
  // one JSON column rather than 40+ scalar columns: adding a nutrient must not cost
  // a migration, and a normalized FoodNutrient table would put ~2M rows in SQLite for
  // 50k foods. Null = no micronutrient data for this food (honest absence, not zero).
  micros   Json?
  createdAt DateTime @default(now())

  ingredientOf RecipeIngredient[]

  @@index([name])
  @@index([source])
}

model Recipe {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  steps       Json // ordered string array
  slotType    String   @default("meal") // "meal" | "snack" | "either"
  cuisine     String?
  prepTimeMin Int?
  source      String   @default("curated") // "curated" | "ai-generated"
  // NEW (roadmap/03-recipe-curation.md §2): null = ordinary meal-eligible
  // (the default for ~88% of the pool). Only set for recipes reviewed and
  // found not to belong in a full lunch/dinner slot on their own merits.
  // Additive - does not change what slotType means for any existing row or
  // call site (slotType is read in 7+ places including a user-facing
  // dropdown and the AI-generation JSON schema; overloading it to encode
  // "this is a dessert" was considered and rejected - see the roadmap doc).
  mealCategory String? // "dessert" | "beverage" | "bread_or_pastry_side" | "condiment_or_sauce" | "breakfast_only" | null
  // cached macros per serving (base ingredient grams, scale=1), recomputed on save
  kcal        Float
  protein     Float
  fat         Float
  carb        Float
  // T (v2): taste-quality tier + cached user-rating aggregate. Nullable/additive;
  // null tasteTier ranks as "decent" and is never filtered out by default. SOFT
  // signal — only the brain scorer reads these; the deterministic solver ignores
  // them, so BRAIN=off stays byte-identical (Law 2 unaffected).
  tasteTier       String? // "decent" | "really_good" | "exceptional"
  tasteTierSource String? // "curated" | "user_derived" | "llm"  (precedence: curated > user_derived > llm)
  userRatingAvg   Float? // cached mean of RecipeRating scores, normalised 0..1
  userRatingCount Int? // cached count of ratings
  createdAt   DateTime @default(now())
  // Nullable on purpose: the existing 629-row curated/AI-generated/imported
  // library predates per-user ownership (single-user app originally) and has
  // no real "creator" - null means "shared library content, admin-only to
  // mutate" (see routes/recipes.js's ownership check). A non-null value
  // means a specific user created this recipe and only that user (or an
  // admin) may edit/delete it.
  createdByUserId String?
  createdBy       User?   @relation(fields: [createdByUserId], references: [id])

  ingredients RecipeIngredient[]
  planSlots   PlanSlot[]
  cartItems   CartItem[]
}

model RecipeIngredient {
  id        String  @id @default(cuid())
  recipeId  String
  recipe    Recipe  @relation(fields: [recipeId], references: [id])
  foodId    String
  food      Food    @relation(fields: [foodId], references: [id])
  baseGrams Float
  scalable  Boolean @default(true) // false = fixed (spices, a single egg, etc.) — not scaled with the recipe multiplier
  role      String? // "protein" | "carb" | "veg" | "fat" | null — informational, not used for selection
}

model Plan {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  startDate String // ISO date, Monday of the week
  createdAt DateTime @default(now())

  slots       PlanSlot[]
  groceryList GroceryList?

  @@unique([userId, startDate])
}

model PlanSlot {
  id          String  @id @default(cuid())
  planId      String
  plan        Plan    @relation(fields: [planId], references: [id])
  dayOfWeek   Int // 0-6, 0 = Monday (matches plan.startDate)
  slotType    String // "meal" | "snack"
  slotIndex   Int // which meal/snack number within the day, 0-based
  recipeId    String?
  recipe      Recipe? @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  // Two independent scale factors — the protein-role ingredient(s) scale
  // separately from the rest of the recipe, so the slot can hit both a
  // calorie AND a protein target (one multiplier over the whole recipe
  // can only hit one or the other unless the recipe's fixed ratio happens
  // to already match).
  proteinScale Float  @default(1)
  sidesScale   Float  @default(1)
  // Ground truth for display + grocery list: actual grams to cook per
  // ingredient, resolved from the scale factors at generation time.
  ingredients Json // [{ foodId, name, grams, role }]
  kcal        Float   @default(0)
  protein     Float   @default(0)
  fat         Float   @default(0)
  carb        Float   @default(0)
  warning     String?
  locked      Boolean @default(false)

  @@unique([planId, dayOfWeek, slotType, slotIndex])
}

model GroceryList {
  id        String   @id @default(cuid())
  planId    String   @unique
  plan      Plan     @relation(fields: [planId], references: [id])
  items     Json // [{ foodId, name, category, grams }]
  createdAt DateTime @default(now())
}

// User-curated recipe collection, independent of the auto-generated week
// plan (PlanSlot). onDelete: Cascade here (not SetNull like PlanSlot) —
// a cart entry pointing at a deleted recipe has no historical value once
// the recipe itself is gone, unlike a past week's plan slot.
model CartItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  recipeId  String
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  addedAt   DateTime @default(now())

  @@unique([userId, recipeId])
}

// T (v2) — recipe taste ratings. A SOFT palatability signal only: it re-ranks
// which recipes the solver PREFERS, never what it may serve (hard diet/allergy
// filters always win) and never a displayed number. Plain columns, no FK: an
// orphan rating for a deleted recipe simply never matches the pool (harmless).
model RecipeRating {
  id        String   @id @default(cuid())
  userId    String
  recipeId  String
  rating    Int // 1 = like, -1 = dislike (no row = neutral)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, recipeId])
  @@index([userId])
}

// Food diary. A logged entry is a SELF-CONTAINED macro snapshot — name +
// kcal/macros are copied in at log time, so a later recipe edit or delete
// never rewrites history. `source` is "planned" (copied from that date's
// PlanSlot rows) or "manual" (hand-entered). `recipeId` is a provenance tag
// only (no FK relation) — it survives recipe deletion because the entry
// carries its own numbers. Spec named Int columns, but this schema uses cuid
// String ids throughout (see User.id), so id/userId are String to keep the
// userId -> User FK valid; kcal stays Int and the three macros Float per spec.
model MealLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String // ISO date (yyyy-mm-dd)
  source    String // "planned" | "manual"
  recipeId  String? // provenance tag only — intentionally not a FK relation
  name      String
  kcal      Int
  proteinG  Float
  carbG     Float
  fatG      Float
  slotType  String? // "meal" | "snack" | null — informational label
  createdAt DateTime @default(now())

  @@index([userId, date])
}

// ==== BRAIN (v3) ==== additive; unused with BRAIN=off. The LLM usage/cost
// ledger so the pre-call cost caps (src/lib/brain/ledger.js) survive restarts.
// userId is nullable (guard/classify spend can precede auth) with a cascade
// relation, matching the standing brain-persistence convention.
model LlmUsage {
  id              String   @id @default(cuid())
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  model           String
  phase           String? // "classify" | "guard" | "plan" | ...
  intent          String?
  inputTokens     Int      @default(0)
  outputTokens    Int      @default(0)
  cacheReadTokens Int      @default(0)
  costUsd         Float    @default(0)
  createdAt       DateTime @default(now())

  @@index([createdAt])
  @@index([userId, createdAt])
}

// ── Brain v3 (Stage I) ──────────────────────────────────────────────────
// SOFT preferences ONLY. Exclusions (diet/allergy) are NEVER stored here —
// they always recompute from Profile, so a stale stored copy can't leak a food
// (LAW 2). Every write goes through prefsStore.sanitizeSoft first. Additive,
// cascade-deleted with the user; inert until the brain is wired.
model BrainPreference {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  data      Json // soft signals: { likedRecipeIds, dislikedRecipeIds, cuisineNudge, notes }
  updatedAt DateTime @updatedAt
}

// ==== BRAIN (v2 Stage I persistence) ==== additive; dormant with BRAIN=off.
// Plain userId (no FK to User) — same pattern as RecipeRating; orphans are
// harmless and it keeps the migration pure CREATE TABLEs. Internal parent→child
// relations cascade. SOFT/history data only — NEVER a source of exclusions (Law 2).
model BrainConversation {
  id        String         @id @default(cuid())
  userId    String
  title     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  messages  BrainMessage[]

  @@index([userId])
}

model BrainMessage {
  id             String            @id @default(cuid())
  conversationId String
  conversation   BrainConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // "user" | "assistant"
  content        String
  createdAt      DateTime          @default(now())

  @@index([conversationId])
}

model GeneratedRecipe {
  id        String   @id @default(cuid())
  userId    String
  recipeId  String? // set once accepted into the pool
  name      String
  data      Json // verified structure + prov
  createdAt DateTime @default(now())

  @@index([userId])
}

model GeneratedPlan {
  id        String              @id @default(cuid())
  userId    String
  label     String?
  data      Json // plan snapshot
  createdAt DateTime            @default(now())
  items     GeneratedPlanItem[]

  @@index([userId])
}

model GeneratedPlanItem {
  id       String        @id @default(cuid())
  planId   String
  plan     GeneratedPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  slotType String // "meal" | "snack"
  recipeId String?
  data     Json

  @@index([planId])
}

model BrainSolveRun {
  id        String   @id @default(cuid())
  userId    String
  intent    String?
  status    String // "converged" | "partial" | "failed"
  data      Json // targets, iterations, result summary (audit)
  createdAt DateTime @default(now())

  @@index([userId])
}

model UserLibraryEntry {
  id        String   @id @default(cuid())
  userId    String
  recipeId  String
  createdAt DateTime @default(now())

  @@unique([userId, recipeId])
  @@index([userId])
}

// ── Training scaffold (Phase 8) ─────────────────────────────────────────
// Deliberately separate from the meal engine: nothing here references
// Recipe/Food/Plan, and the meal code never reads these tables. The tree
// is plan → weeks → sessions → exercises, mirroring how a program is
// actually periodized, so later versions (deloads, per-week progression,
// exercise swaps, logging actual lifts) fit without a schema rewrite.

model TrainingPlan {
  id               String   @id @default(cuid())
  userId           String   @unique // v1: one active plan; regenerating replaces it
  user             User     @relation(fields: [userId], references: [id])
  name             String
  // The inputs the generator matched on — kept so regenerate can pre-fill
  // the form and the plan can explain why it looks the way it does.
  style            String // "strength" | "hypertrophy" | "general" | "conditioning"
  experience       String // "beginner" | "intermediate" | "advanced"
  daysPerWeek      Int
  sessionLengthMin Int
  equipment        Json // string[] of equipment keys
  templateKey      String // which v1 template was chosen
  generator        String   @default("v1-templates") // provenance label
  createdAt        DateTime @default(now())
  weeks            TrainingWeek[]
}

model TrainingWeek {
  id         String            @id @default(cuid())
  planId     String
  plan       TrainingPlan      @relation(fields: [planId], references: [id], onDelete: Cascade)
  weekNumber Int // 1-based
  note       String? // week-level coaching note (progression guidance in v1)
  sessions   TrainingSession[]

  @@unique([planId, weekNumber])
}

model TrainingSession {
  id        String             @id @default(cuid())
  weekId    String
  week      TrainingWeek       @relation(fields: [weekId], references: [id], onDelete: Cascade)
  dayIndex  Int // 0-based order within the week — not tied to calendar days
  name      String // "Full Body A", "Upper 1", …
  focus     String?
  exercises TrainingExercise[]

  @@unique([weekId, dayIndex])
}

model TrainingExercise {
  id        String          @id @default(cuid())
  sessionId String
  session   TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  order     Int
  name      String
  sets      Int
  reps      String // "5", "8-12", "40s" — ranges and time-based work are real prescriptions
  rpe       Float? // null where RPE isn't the dial (conditioning circuits)
  restSec   Int?
  notes     String?

  @@unique([sessionId, order])
}
