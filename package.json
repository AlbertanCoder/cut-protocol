{
  "name": "cut-protocol-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Cut Protocol — Windows desktop shell (Electron) around the existing Express+Prisma+React app.",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "electron .",
    "build:frontend": "npm --prefix frontend run build",
    "dist:template": "node backend/scripts/buildTemplateDb.mjs",
    "predist": "node backend/scripts/buildTemplateDb.mjs && node scripts/distPrecheck.mjs",
    "dist": "npm run build:frontend && electron-builder",
    "scan:secrets": "node scripts/scanSecrets.mjs --tracked",
    "brain:purity": "node scripts/checkBrainPurity.mjs",
    "supply:check": "node scripts/checkSupplyChain.mjs",
    "security:all": "node scripts/scanSecrets.mjs --tracked && node scripts/checkBrainPurity.mjs && node scripts/checkSupplyChain.mjs",
    "dist:check": "node scripts/checkDistSafe.mjs"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.cutprotocol.app",
    "productName": "Cut Protocol",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "backend/**/*",
      "frontend/dist/**/*",
      "CutProtocol.ico",
      "!backend/prisma/dev.db",
      "!backend/prisma/dev.db-journal",
      "!backend/prisma/dev.db.template",
      "!backend/prisma/dev.db.backup-*",
      "!backend/prisma/*.db.backup*",
      "!backend/.env",
      "!backend/.env.local",
      "!backend/tests/**/*",
      "!backend/scripts/**/*",
      "!backend/data/*.backup*",
      "!**/*.test.js",
      "!**/*.map",
      "!**/*.backup-*",
      "!AUDIT.md",
      "!PABLO_REVIEW.md",
      "!CLAUDE*.md",
      "!PROGRESS.md",
      "!docs/**/*",
      "!release/**/*",
      "!.agent/**/*",
      "!**/node_modules/.cache/**/*",
      "!**/.git/**/*"
    ],
    "asarUnpack": [
      "backend/node_modules/.prisma/**/*",
      "backend/node_modules/@prisma/**/*",
      "backend/node_modules/prisma/**/*",
      "backend/prisma/**/*"
    ],
    "extraResources": [
      { "from": "backend/prisma/dev.db.template", "to": "dev.db.template" }
    ],
    "win": {
      "icon": "CutProtocol.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Cut Protocol"
    }
  }
}
